aws {
    // Service account credentials — get from Terraform after apply:
    // terraform output nextflow_runner_access_key_id
    // terraform output -raw nextflow_runner_secret_access_key
    accessKey = 'REPLACE_WITH_ACCESS_KEY'
    secretKey = 'REPLACE_WITH_SECRET_KEY'
    region    = 'us-east-1'

    batch {
        // Path to AWS CLI on the EC2 instance
        cliPath = '/usr/local/bin/aws'

        // IAM role attached to every running container
        // terraform output batch_job_role_arn
        jobRole = 'REPLACE_WITH_BATCH_JOB_ROLE_ARN'
    }

    client {
        maxConnections     = 20
        uploadStorageClass = 'INTELLIGENT_TIERING'
    }
}

docker {
    enabled = true
}

process {
    withName: fastqc {
        memory    = '7.GB'
        cpus      = 2
        executor  = 'awsbatch'
        queue     = 'seqwell-batch-queue'
        container = 'seqwell/fastqc-awscli:v0.11.3'
    }
    withName: multiqc {
        memory    = '7.GB'
        cpus      = 2
        executor  = 'awsbatch'
        queue     = 'seqwell-batch-queue'
        container = 'cautree/multiqc:latest'
    }
    withName: get_ATCG_counts {
        memory    = '7.GB'
        cpus      = 2
        executor  = 'awsbatch'
        queue     = 'seqwell-batch-queue'
        container = '512431263418.dkr.ecr.us-east-1.amazonaws.com/python-pandas'
    }
}
